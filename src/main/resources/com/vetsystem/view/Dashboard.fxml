<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.vetsystem.controller.DashboardController"
            style="-fx-background-color: #f0f4f8;">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="VetSystem" 
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Sistema de Gestión Veterinaria"
                   style="-fx-font-size: 12px; -fx-text-fill: #bdc3c7;"/>
        </HBox>
    </top>

    <!-- MENU LATERAL -->
    <left>
        <VBox spacing="5" style="-fx-background-color: #34495e; -fx-padding: 10;">
            <Button text="Pacientes" onAction="#abrirPacientes" maxWidth="150"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;"/>
            <Button text="Dueños" onAction="#abrirDuenos" maxWidth="150"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;"/>
            <Button text="Consultas" onAction="#abrirConsultas" maxWidth="150"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;"/>
            <Button text="Medicamentos" onAction="#abrirMedicamentos" maxWidth="150"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;"/>
            <Button fx:id="btnCerrarSesion" text="Cerrar Sesión" onAction="#cerrarSesion" maxWidth="150"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- CONTENIDO CENTRAL -->
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">
            <Label text="Bienvenido a VetSystem"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Seleccione una opción del menú lateral"
                   style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
    </center>

</BorderPane>