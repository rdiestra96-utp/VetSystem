<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vetsystem.controller.DuenosController"
      spacing="10" style="-fx-background-color: #f0f4f8; -fx-padding: 20;">

    <Label text="Gestión de Dueños"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <!-- Formulario -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtNombre" promptText="Nombre" prefWidth="120"/>
        <TextField fx:id="txtApellido" promptText="Apellido" prefWidth="120"/>
        <TextField fx:id="txtDni" promptText="DNI" prefWidth="90"/>
        <TextField fx:id="txtTelefono" promptText="Teléfono" prefWidth="100"/>
        <TextField fx:id="txtDireccion" promptText="Dirección" prefWidth="150"/>
    </HBox>

    <!-- Botones -->
    <HBox spacing="10">
        <Button text="Agregar" onAction="#agregar"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="Eliminar" onAction="#eliminar"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="Limpiar" onAction="#limpiar"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <TextField fx:id="txtFiltro" promptText="Buscar por nombre..." prefWidth="180"/>
        <Button text="Buscar" onAction="#buscar"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <!-- Tabla -->
    <TableView fx:id="tablaDuenos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="120"/>
            <TableColumn fx:id="colApellido" text="Apellido" prefWidth="120"/>
            <TableColumn fx:id="colDni" text="DNI" prefWidth="90"/>
            <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="100"/>
            <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="150"/>
        </columns>
    </TableView>

    <Label fx:id="lblMensaje" style="-fx-text-fill: green;"/>

</VBox>